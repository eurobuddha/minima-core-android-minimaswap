<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Minima data comes from the local node over broadcast-Intent IPC. Package visibility lets us
         launch the node app + deliver targeted broadcasts. -->
    <queries>
        <package android:name="org.minimarex.minimacore" />
    </queries>

    <!-- Unlike the node-only merch apps, minimaSwap also talks to the Ethereum network directly
         (JSON-RPC to a user-configured endpoint) for the ERC20 leg of each atomic swap. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Swap-status notifications (Android 13+ prompts at runtime). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Scan a counterparty / order QR. -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Background swap watcher: a foreground service drives the swap engine whenever the node is
         reachable, so swaps progress with the app closed (the node alone isn't enough — we're a
         separate process). Battery exemption keeps the OS from doze-killing it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Utxo"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".SwapService"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
